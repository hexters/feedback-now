{
    "name": "hexters/feedback-now",
    "description": "In-app feedback and bug reporting for Laravel: a floating button that turns client reports with annotated screenshots into GitHub or GitLab issues.",
    "keywords": ["laravel", "php", "feedback", "in-app-feedback", "bug-report", "bug-tracker", "issue-tracker", "report-issue", "github", "github-issues", "gitlab", "screenshot", "annotation", "fab"],
    "license": "MIT",
    "authors": [
        {
            "name": "Asep SS",
            "email": "hexters@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Hexters\\FeedbackNow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hexters\\FeedbackNow\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hexters\\FeedbackNow\\FeedbackNowServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
